{
  "name": "smileguard",
  "version": "1.0.0",
  "description": "SmileGuard - AI-powered dental management system",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "doctor:start": "pnpm --filter doctor-mobile start",
    "doctor:android": "pnpm --filter doctor-mobile android",
    "doctor:ios": "pnpm --filter doctor-mobile ios",
    "patient:dev": "pnpm --filter patient-web dev",
    "patient:build": "pnpm --filter patient-web build",
    "lint": "pnpm --filter doctor-mobile lint"
  },
  "dependencies": {
    "expo": "53.0.0",
    "react": "^19.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  },
  "private": true,
  "packageManager": "pnpm@9.0.0"
}
