{
  "name": "smileguard",
  "version": "1.0.0",
  "description": "SmileGuard - AI-powered dental management system",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "doctor:start": "cd apps/doctor-mobile && expo start",
    "doctor:android": "cd apps/doctor-mobile && expo start --android",
    "doctor:ios": "cd apps/doctor-mobile && expo start --ios",
    "patient:dev": "cd apps/patient-web && npm run dev",
    "patient:build": "cd apps/patient-web && npm run build",
    "lint": "cd apps/doctor-mobile && expo lint"
  },
  ],
  "dependencies": {},
  "devDependencies": {},
  "private": true
}
